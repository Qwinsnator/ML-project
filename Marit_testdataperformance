import numpy as np
import pandas as pd
from sklearn.svm import SVC
from sklearn.preprocessing import RobustScaler
from sklearn.impute import SimpleImputer
from sklearn.metrics import accuracy_score, f1_score, recall_score, roc_auc_score

# --- Globale state om 'leermomenten' op te slaan ---
fit_state = {
    'imputer1': SimpleImputer(strategy="median"),
    'imputer2': SimpleImputer(strategy="median"),
    'scaler': RobustScaler(),
    'means': None,
    'stds': None
}

def preprocess(df, is_test=False):
    X = df.select_dtypes(np.number)
    print(f"Preprocess {X.shape} (Test={is_test})")
    
    # Stap 1: Eerste imputatie
    if not is_test:
        X_imp = fit_state['imputer1'].fit_transform(X)
        # Bereken m en s van de training set
        fit_state['means'] = np.mean(X_imp, axis=0)
        fit_state['stds'] = np.std(X_imp, axis=0)
    else:
        X_imp = fit_state['imputer1'].transform(X)

    # Stap 2: Outlier handling met training statistieken
    X_out = np.copy(X_imp)
    for j in range(X.shape[1]):
        m, s = fit_state['means'][j], fit_state['stds'][j]
        mask = (X_imp[:, j] < m - 3*s) | (X_imp[:, j] > m + 3*s)
        X_out[mask, j] = np.nan # FIX: alleen cel j op nan, niet hele rij [mask, :]
    
    # Stap 3: Tweede imputatie en scaling
    if not is_test:
        X_clean = fit_state['imputer2'].fit_transform(X_out)
        return fit_state['scaler'].fit_transform(X_clean)
    else:
        X_clean = fit_state['imputer2'].transform(X_out)
        return fit_state['scaler'].transform(X_clean)

# --- UITVOERING ---

# 1. Training data (moet eerst om te fitten!)
df_train = pd.read_csv('GIST_Train.csv')
y_train = df_train['label'].map({'GIST':1, 'non-GIST':0}).values
X_train = preprocess(df_train, is_test=False)

# 2. Test data (gebruikt fit_state van training)
df_test = pd.read_csv('GIST_Test.csv')
X_test = preprocess(df_test, is_test=True)

# 3. Feature selectie
feat_df = pd.read_csv('results_grid/selected_features_indices.csv')
indices = feat_df['index'].astype(int)
X_train_sel = X_train[:, indices]
X_test_sel = X_test[:, indices]
print(f"Selected features: {X_test_sel.shape[1]}")

# 4. Model Training
model = SVC(C=0.1, kernel='linear', probability=True, random_state=42)
model.fit(X_train_sel, y_train)

# 5. Voorspellen op testdata
pred = model.predict(X_test_sel)
prob = model.predict_proba(X_test_sel)[:,1]
y_test = df_test['label'].map({'GIST':1, 'non-GIST':0}).values

# 6. Metrics
mis = (pred != y_test).sum()
acc = accuracy_score(y_test, pred)
f1 = f1_score(y_test, pred)
rec = recall_score(y_test, pred)
auc = roc_auc_score(y_test, prob)
spec = recall_score(y_test, pred, pos_label=0)

# Opslaan en printen
out = pd.DataFrame({'prediction': pred, 'prob': prob, 'true': y_test})
out.to_csv('predictions.csv', index=False)

print("-" * 30)
print(f"Misclassifications: {mis}")
print(f"Accuracy: {acc:.3f}")
print(f"AUC: {auc:.3f}")
print(f"Recall GIST: {rec:.3f}")
print(f"Specificity: {spec:.3f}")
print(f"F1: {f1:.3f}")